{
  "compilerOptions": {
    "types": ["mocha", "chai"],
    "typeRoots": ["./node_modules/@types"],
    "lib": ["es2015"],
    "module": "commonjs",
    "target": "es6",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@starke/sdk": ["sdk-ts/index"],
      "@starke/sdk/*": ["sdk-ts/*"],
      "@starke/idl/*": ["target/idl/*"]
    }
  }
}
