#!/bin/sh

# Check if RPC endpoint is provided
if [ -z "$MAINNET_RPC" ]; then
    echo "Error: MAINNET_RPC environment variable is not set"
    echo "Please set it using: export MAINNET_RPC=<your-rpc-endpoint>"
    exit 1
fi

# NOTE: Can not use verifiable build unless anchor fixes their issue
#       https://github.com/coral-xyz/anchor/issues/3585
# anchor deploy -p vaults -v --provider.cluster $MAINNET_RPC
anchor deploy -p vaults --provider.cluster $MAINNET_RPC
